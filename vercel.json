{
  "builds": [],
  "routes": [
    { "src": "/pos", "dest": "/pos.html" },
    { "src": "/tienda", "dest": "/tienda.html" },
    { "src": "/index", "dest": "/index.html" },
    { "src": "/migrar", "dest": "/migrar.html" },
    { "src": "/migrar-imagenes", "dest": "/migrar-imagenes.html" },
    { "src": "/ver-datos", "dest": "/ver-datos.html" },
    { "src": "/(.+)\\.html", "dest": "/$1.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
